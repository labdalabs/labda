# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.nx/cache
.nx/workspace-data
.claude/worktrees
.claude/settings.local.json

# env files (never commit — contain secrets)
.env
.env.local
.env.*.local

# Next.js
.next
out
# Supabase local state
supabase/.branches
supabase/.temp

# eve agent build artifacts
apps/copilot/.output
apps/copilot/.eve
apps/copilot/.nitro

# electron-builder output (macOS desktop app)
apps/desktop/release

# vscode extension build output
apps/plugin/out
apps/plugin/*.vsix
.vercel

# vercel/railway local link state
apps/**/.vercel
infra/**/.railway
