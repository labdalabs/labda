# ─── API ────────────────────────────────────────────────────────────────────
PORT=3001
LOG_LEVEL=info
LOG_PRETTY=true
FRONTEND_URL=http://localhost:3000
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
# Local (from `pnpm supabase status` → DB URL)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
DATABASE_MAX=20
DATABASE_SSL=false

# ─── Supabase ────────────────────────────────────────────────────────────────
# Local defaults (from `pnpm supabase status`)
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Semantic Scholar (literature search) ────────────────────────────────────
# Public API works without a key (rate-limited). Request a key for higher
# limits: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
# SEMANTIC_SCHOLAR_API_KEY=

# ─── UI (Next.js public vars) ────────────────────────────────────────────────
# Public URL of the Nest API (with the /api global prefix).
NEXT_PUBLIC_API_URL=http://localhost:3001/api
# Anon key + URL from `pnpm supabase status` (or your cloud project dashboard).
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Channel name for the Nest EventBus — must match libs/core/common DOMAIN_EVENTS_CHANNEL.
NEXT_PUBLIC_DOMAIN_EVENTS_CHANNEL=labda:domain-events
